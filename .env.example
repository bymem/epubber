# Copy this file to .env and adjust as needed. .env is gitignored.

# Folder to scan for story .txt files.
# Relative paths are resolved against the project root; absolute paths are used as-is.
SCAN_FOLDER=stories

# Folder where built epub packages are written.
# Relative paths are resolved against the project root; absolute paths are used as-is.
OUTPUT_FOLDER=temp

# Default language code used in the epub metadata (dc:language)
LANGUAGE=en
