# Copy this file to .env and adjust as needed. .env is gitignored.

# Folder to scan for story .txt files.
# Relative paths are resolved against the project root; absolute paths are used as-is.
SCAN_FOLDER=stories

# Scratch folder used while generating chapter HTML etc. Cleared per series on each rebuild.
# Relative paths are resolved against the project root; absolute paths are used as-is.
WORK_FOLDER=temp

# Folder where the finished .epub files are placed.
# Relative paths are resolved against the project root; absolute paths are used as-is.
OUTPUT_FOLDER=output

# Default language code used in the epub metadata (dc:language)
LANGUAGE=en

# Optional: path to a .ttf font used to draw the title onto the cover image.
# If unset, a few common system font locations are tried automatically. Requires the GD
# extension (check with: php -m | grep -i gd).
# COVER_FONT=
